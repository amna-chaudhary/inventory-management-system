@model MVCPro.Models.SalesOrder

@{
    ViewBag.Title = "Delete Sales Order";
}

<h2>Delete Sales Order</h2>

<h4>Are you sure you want to delete the following sales order?</h4>

<div class="form-group">
    <label>Order Number</label>
    <p>@Model.SalesOrderNumber</p>
</div>

<div class="form-group">
    <label>Customer</label>
    <p>@Model.CustomerName</p>
</div>

<div class="form-group">
    <label>Order Date</label>
    <p>@Model.OrderDate.ToShortDateString()</p>
</div>

<div class="form-group">
    <label>Expected Shipment Date</label>
    <p>@Model.ExpectedShipmentDate?.ToShortDateString() ?? "N/A"</p>
</div>

<div class="form-group">
    <label>Total Amount</label>
    <p>@Model.TotalAmount.ToString("C")</p>
</div>

@using (Html.BeginForm("Delete", "SalesOrder", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)

    <div class="form-group">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="@Url.Action("Index", "SalesOrder")" class="btn btn-secondary">Cancel</a>
    </div>
}
