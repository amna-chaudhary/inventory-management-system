@model IEnumerable<MVCPro.Models.SalesOrder>

@{
    ViewBag.Title = "Sales Orders";
}

<h2>Sales Orders</h2>

<p>
    @Html.ActionLink("Create New Order", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Order No</th>
            <th>Customer</th>
            <th>Order Date</th>
            <th>Total Amount</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.SalesOrderNumber</td>
                <td>@order.CustomerName</td>
                <td>@order.OrderDate.ToShortDateString()</td>
                <td>@order.TotalAmount.ToString("C")</td>
                <td>
                    @Html.ActionLink("Details", "Details", new { id = order.Id }) |
                    @Html.ActionLink("Edit", "Edit", new { id = order.Id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = order.Id })
                </td>
            </tr>
        }
    </tbody>
</table>
