@model MVCPro.Models.Vendor

@{
    ViewBag.Title = "Edit Vendor";
}

<h2>Edit Vendor</h2>

@using (Html.BeginForm("Edit", "Vendor", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row">
            <div class="col-md-6">
                @Html.LabelFor(model => model.VendorType)
                @Html.TextBoxFor(model => model.VendorType, new { @class = "form-control" })

                @Html.LabelFor(model => model.Salutation)
                @Html.TextBoxFor(model => model.Salutation, new { @class = "form-control" })

                @Html.LabelFor(model => model.FirstName)
                @Html.TextBoxFor(model => model.FirstName, new { @class = "form-control" })

                @Html.LabelFor(model => model.LastName)
                @Html.TextBoxFor(model => model.LastName, new { @class = "form-control" })

                @Html.LabelFor(model => model.CompanyName)
                @Html.TextBoxFor(model => model.CompanyName, new { @class = "form-control" })

                @Html.LabelFor(model => model.CompanyId)
                @Html.TextBoxFor(model => model.CompanyId, new { @class = "form-control" })

                @Html.LabelFor(model => model.Email)
                @Html.TextBoxFor(model => model.Email, new { @class = "form-control", type = "email" })

                @Html.LabelFor(model => model.Phone)
                @Html.TextBoxFor(model => model.Phone, new { @class = "form-control" })

                @Html.LabelFor(model => model.DocumentPath, "Upload Document (optional)")
                <input type="file" name="document" class="form-control" />
            </div>

            <div class="col-md-6">
                @Html.LabelFor(model => model.BillingCity)
                @Html.TextBoxFor(model => model.BillingCity, new { @class = "form-control" })

                @Html.LabelFor(model => model.BillingState)
                @Html.TextBoxFor(model => model.BillingState, new { @class = "form-control" })

                @Html.LabelFor(model => model.BillingCountry)
                @Html.TextBoxFor(model => model.BillingCountry, new { @class = "form-control" })

                @Html.LabelFor(model => model.BillingPostalCode)
                @Html.TextBoxFor(model => model.BillingPostalCode, new { @class = "form-control" })

                @Html.LabelFor(model => model.ShippingCity)
                @Html.TextBoxFor(model => model.ShippingCity, new { @class = "form-control" })

                @Html.LabelFor(model => model.ShippingState)
                @Html.TextBoxFor(model => model.ShippingState, new { @class = "form-control" })

                @Html.LabelFor(model => model.ShippingCountry)
                @Html.TextBoxFor(model => model.ShippingCountry, new { @class = "form-control" })

                @Html.LabelFor(model => model.ShippingPostalCode)
                @Html.TextBoxFor(model => model.ShippingPostalCode, new { @class = "form-control" })
            </div>
        </div>

        <br />
        <div class="form-group">
            <input type="submit" value="Save" class="btn btn-success" />
        </div>
    </div>
}
