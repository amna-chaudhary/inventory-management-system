@model MVCPro.Models.Vendor

@{
    ViewBag.Title = "Vendor Details";
}

<h2 class="mb-4">Vendor Details</h2>

<div class="card shadow p-4 mb-4">
    <h4 class="mb-3 text-primary">Personal Info</h4>
    <div class="row">
        <div class="col-md-6">
            <p><strong>Vendor Type:</strong> @Model.VendorType</p>
            <p><strong>Salutation:</strong> @Model.Salutation</p>
            <p><strong>First Name:</strong> @Model.FirstName</p>
            <p><strong>Last Name:</strong> @Model.LastName</p>
        </div>
        <div class="col-md-6">
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
        </div>
    </div>
</div>

<div class="card shadow p-4 mb-4">
    <h4 class="mb-3 text-primary">Company Info</h4>
    <p><strong>Company Name:</strong> @Model.CompanyName</p>
    <p><strong>Company ID:</strong> @Model.CompanyId</p>
</div>

<div class="card shadow p-4 mb-4">
    <h4 class="mb-3 text-primary">Billing Address</h4>
    <div class="row">
        <div class="col-md-6">
            <p><strong>City:</strong> @Model.BillingCity</p>
            <p><strong>State:</strong> @Model.BillingState</p>
        </div>
        <div class="col-md-6">
            <p><strong>Country:</strong> @Model.BillingCountry</p>
            <p><strong>Postal Code:</strong> @Model.BillingPostalCode</p>
        </div>
    </div>
</div>

<div class="card shadow p-4 mb-4">
    <h4 class="mb-3 text-primary">Shipping Address</h4>
    <div class="row">
        <div class="col-md-6">
            <p><strong>City:</strong> @Model.ShippingCity</p>
            <p><strong>State:</strong> @Model.ShippingState</p>
        </div>
        <div class="col-md-6">
            <p><strong>Country:</strong> @Model.ShippingCountry</p>
            <p><strong>Postal Code:</strong> @Model.ShippingPostalCode</p>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.DocumentPath))
{
    <div class="card shadow p-4 mb-4">
        <h4 class="mb-3 text-primary">Uploaded Document</h4>
        <p>
            <strong>File:</strong>
            <a href="@Url.Content(Model.DocumentPath)" target="_blank" class="btn btn-outline-info btn-sm">
                View / Download Document
            </a>
        </p>
    </div>
}

<div class="mt-3">
    @Html.ActionLink("Edit", "Edit", new { id = Model.Id }, new { @class = "btn btn-warning" }) |
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
</div>
