@model MVCPro.Models.Vendor

@{
    ViewBag.Title = "Delete Vendor";
}

<h2>Delete Vendor</h2>

<h4>Are you sure you want to delete this vendor?</h4>
<hr />

<div class="form-horizontal">
    <div class="row">
        <div class="col-md-6">
            <p><strong>Vendor Type:</strong> @Model.VendorType</p>
            <p><strong>Salutation:</strong> @Model.Salutation</p>
            <p><strong>First Name:</strong> @Model.FirstName</p>
            <p><strong>Last Name:</strong> @Model.LastName</p>
            <p><strong>Company Name:</strong> @Model.CompanyName</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
        </div>
        <div class="col-md-6">
            <p><strong>Billing City:</strong> @Model.BillingCity</p>
            <p><strong>Billing State:</strong> @Model.BillingState</p>
            <p><strong>Shipping City:</strong> @Model.ShippingCity</p>
            <p><strong>Shipping State:</strong> @Model.ShippingState</p>
            <p><strong>Document Path:</strong> @Model.DocumentPath</p>
        </div>
    </div>
</div>

@using (Html.BeginForm("Delete", "Vendor", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)

    <div class="form-group mt-3">
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary" })
    </div>
}
