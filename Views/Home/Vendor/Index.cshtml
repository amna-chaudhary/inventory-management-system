@model IEnumerable<MVCPro.Models.Vendor>

@{
    ViewBag.Title = "Vendor List";
}

<h2>Vendor List</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().VendorType)</th>
            <th>@Html.DisplayNameFor(model => model.First().Salutation)</th>
            <th>@Html.DisplayNameFor(model => model.First().FirstName)</th>
            <th>@Html.DisplayNameFor(model => model.First().LastName)</th>
            <th>@Html.DisplayNameFor(model => model.First().CompanyName)</th>
            <th>@Html.DisplayNameFor(model => model.First().CompanyId)</th>
            <th>@Html.DisplayNameFor(model => model.First().Email)</th>
            <th>@Html.DisplayNameFor(model => model.First().Phone)</th>
            <th>@Html.DisplayNameFor(model => model.First().BillingCity)</th>
            <th>@Html.DisplayNameFor(model => model.First().BillingState)</th>
            <th>@Html.DisplayNameFor(model => model.First().BillingCountry)</th>
            <th>@Html.DisplayNameFor(model => model.First().BillingPostalCode)</th>
            <th>@Html.DisplayNameFor(model => model.First().ShippingCity)</th>
            <th>@Html.DisplayNameFor(model => model.First().ShippingState)</th>
            <th>@Html.DisplayNameFor(model => model.First().ShippingCountry)</th>
            <th>@Html.DisplayNameFor(model => model.First().ShippingPostalCode)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.VendorType)</td>
                <td>@Html.DisplayFor(modelItem => item.Salutation)</td>
                <td>@Html.DisplayFor(modelItem => item.FirstName)</td>
                <td>@Html.DisplayFor(modelItem => item.LastName)</td>
                <td>@Html.DisplayFor(modelItem => item.CompanyName)</td>
                <td>@Html.DisplayFor(modelItem => item.CompanyId)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                <td>@Html.DisplayFor(modelItem => item.BillingCity)</td>
                <td>@Html.DisplayFor(modelItem => item.BillingState)</td>
                <td>@Html.DisplayFor(modelItem => item.BillingCountry)</td>
                <td>@Html.DisplayFor(modelItem => item.BillingPostalCode)</td>
                <td>@Html.DisplayFor(modelItem => item.ShippingCity)</td>
                <td>@Html.DisplayFor(modelItem => item.ShippingState)</td>
                <td>@Html.DisplayFor(modelItem => item.ShippingCountry)</td>
                <td>@Html.DisplayFor(modelItem => item.ShippingPostalCode)</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                </td>
            </tr>
        }
    </tbody>
</table>
