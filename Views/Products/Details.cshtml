@model MVCPro.Models.CustomerTable

@{
    ViewBag.Title = "Customer Details";
}

<h2>Customer Details</h2>

<div>
    <h4>Customer Information</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Id</dt>
        <dd>@Model.Id</dd>
        <dt>Customer Type</dt>
        <dd>@Model.CustomerType</dd>
        <dt>Salutation</dt>
        <dd>@Model.Salutation</dd>
        <dt>First Name</dt>
        <dd>@Model.FirstName</dd>
        <dt>Last Name</dt>
        <dd>@Model.LastName</dd>
        <dt>Display Name</dt>
        <dd>@Model.DisplayName</dd>
        <dt>Email</dt>
        <dd>@Model.Email</dd>
        <dt>Phone</dt>
        <dd>@Model.Phone</dd>
        <dt>Billing City</dt>
        <dd>@Model.BillingCity</dd>
        <dt>Billing State</dt>
        <dd>@Model.BillingState</dd>
        <dt>Billing Country</dt>
        <dd>@Model.BillingCountry</dd>
        <dt>Billing Postal Code</dt>
        <dd>@Model.BillingPostalCode</dd>
        <dt>Shipping City</dt>
        <dd>@Model.ShippingCity</dd>
        <dt>Shipping State</dt>
        <dd>@Model.ShippingState</dd>
        <dt>Shipping Country</dt>
        <dd>@Model.ShippingCountry</dd>
        <dt>Shipping Postal Code</dt>
        <dd>@Model.ShippingPostalCode</dd>
    </dl>
</div>

@Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
